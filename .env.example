# Public site URL — used for canonical URLs, sitemap, robots and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=https://www.worldofwooddecoration.com

# Contact form → Telegram notifications
# 1) Open Telegram, find @BotFather, send /newbot and create a bot → copy the token.
# 2) Open your new bot in Telegram and press Start (send any message).
# 3) Open in browser: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat":{"id":123456789} → that number is TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: destination inbox for email fallback (not wired yet).
CONTACT_INBOX_EMAIL=info@worldofwooddecoration.com

# Admin CMS (/admin) — change these in production
ADMIN_PASSWORD=admin123
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
